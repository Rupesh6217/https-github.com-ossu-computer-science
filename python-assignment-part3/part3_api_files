    "        \"description\": \"A product I created via API\"\n",
    "    }\n",
    "\n",
    "    response = requests.post(f\"{BASE_URL}/add\", json=new_product, timeout=5)\n",
    "    response.raise_for_status()\n",
    "    print(\"\\nAPI POST Success:\", response.json())\n",
